# ──────────────────────────────────────────────
# LLM backend selector
# Supported values: openai | vllm | ollama
# ──────────────────────────────────────────────
LLM_PROVIDER=openai

# ── OpenAI (cloud) ────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: override the API base URL (leave blank for default)
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── vLLM (local server, OpenAI-compatible) ────
# Start your server with e.g.:
#   vllm serve google/gemma-3-4b-it --port 8000
#
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_API_KEY=EMPTY          # vLLM ignores this, but the client requires a value
# LLM_MODEL=google/gemma-3-4b-it

# ── Ollama (local, native library) ────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3

# ── Shared ────────────────────────────────────
# Maximum parallel LLM threads
LLM_MAX_WORKERS=200
