# ──────────────────────────────────────────────
# LLM backend selector
# Supported values: openai | vllm | ollama
# ──────────────────────────────────────────────

# ── Ollama — NYUAD HPC default ────────────────
# The SLURM script starts ollama serve automatically and sets
# OLLAMA_HOST / LLM_PROVIDER / LLM_MODEL at runtime.
# These values are the fallback for local development only.
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:e4b

# ── OpenAI (cloud) ────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ── vLLM (local server, OpenAI-compatible) ────
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_API_KEY=EMPTY
# LLM_MODEL=google/gemma-3-4b-it

# ── Shared ────────────────────────────────────
# Maximum parallel LLM threads
LLM_MAX_WORKERS=200
